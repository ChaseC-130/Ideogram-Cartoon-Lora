# Optional: used by scripts that call Gemini for image captions/prompt rewrites.
GEMINI_API_KEY=

# Optional: required by Hugging Face for gated Ideogram model downloads.
HF_TOKEN=

# Path to a local clone of AI Toolkit.
AI_TOOLKIT_PATH=../ai-toolkit

# Optional: used by official Ideogram tooling/magic prompt flows.
IDEOGRAM_API_KEY=
